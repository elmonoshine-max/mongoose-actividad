<!DOCTYPE html>
<html lang="es">
<head>
    <%- include('../partials/head'); %>
</head>
<body>

    <%- include('../partials/header'); %>

    <div style="background-color:#e9ecef; padding:40px 60px; min-height:60vh;">

        <h1><%= palabra %></h1>

        <ul>
            <% mascotas.forEach(function(mascota) { %>
                <li>
                    <%= mascota.tagline %> - Nació en <%= mascota.born %>
                </li>
            <% }); %>
        </ul>

        <hr>

        <h2>Servicios</h2>

        <% if (servicios && servicios.length > 0) { %>
            <ul>
                <% servicios.forEach(function(servicio) { %>
                    <li>
                        <strong><%= servicio.nombre %></strong>
                        - $<%= servicio.precio %>
                        - <%= servicio.categoria %>
                    </li>
                <% }); %>
            </ul>
        <% } else { %>
            <p>No hay servicios registrados.</p>
        <% } %>

    </div>

    <%- include('../partials/footer'); %>

</body>
</html>